{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@gentleduck/example-shared",
  "private": true,
  "engines": {
    "bun": ">=1.3.5"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./access": "./src/access.ts",
    "./prisma": "./src/prisma.ts",
    "./sync": "./src/sync-attributes.ts"
  },
  "scripts": {
    "check-types": "bunx prisma generate && tsc --noEmit",
    "db:migrate": "bunx prisma migrate dev --name access_engine",
    "db:seed": "bun prisma/seed.ts",
    "db:reset": "bunx prisma migrate reset && bun prisma/seed.ts",
    "setup": "bunx prisma migrate dev --name access_engine && bunx prisma generate && bun prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "duck-iam": "workspace:*"
  },
  "devDependencies": {
    "@gentleduck/typescript-config": "workspace:*",
    "@types/node": "22.19.3",
    "prisma": "^6.0.0",
    "typescript": "5.9.3"
  },
  "prisma": {
    "seed": "bun prisma/seed.ts"
  }
}
